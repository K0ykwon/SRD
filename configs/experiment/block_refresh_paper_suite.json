{
  "benchmarks": [
    "delayed_kv",
    "needle",
    "delayed_copy"
  ],
  "variants": [
    "local_only",
    "refresh_no_sufficiency",
    "refresh_with_sufficiency"
  ],
  "variant_model_configs": {
    "local_only": "configs/model/block_refresh_local_only.json",
    "refresh_no_sufficiency": "configs/model/block_refresh_no_sufficiency.json",
