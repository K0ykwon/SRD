{
  "optimizer": "adamw",
  "lr": 0.0002,
  "weight_decay": 0.1,
  "betas": [
    0.9,
    0.95
  ],
  "grad_clip_norm": 1.0,
  "warmup_steps": 1000,
  "lr_schedule": "cosine",
  "micro_batch_size": 1,
  "gradient_accumulation_steps": 32,
  "batch_size_tokens": 8192,
  "max_steps": 12000,
  "eval_every": 1000,
  "save_every": 1000,
  "log_every": 50,
  "precision": "bf16",
  "compile_model": false,
  "deterministic_algorithms": false
}
