{
  "optimizer": "adamw",
  "lr": 0.0003,
  "weight_decay": 0.1,
  "betas": [0.9, 0.95],
  "grad_clip_norm": 1.0,
  "warmup_steps": 50,
  "lr_schedule": "cosine",
  "micro_batch_size": 4,
  "gradient_accumulation_steps": 2,
  "batch_size_tokens": 1024,
  "max_steps": 500,
  "eval_every": 100,
  "save_every": 500,
  "log_every": 50,
  "precision": "fp32",
  "compile_model": false,
  "deterministic_algorithms": false
}
